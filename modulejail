#!/bin/sh
# ModuleJail — shrink a Linux host's kernel-module attack surface.
# Phase 1: CLI parsing, baseline profile definitions, writability gate.
# See CLAUDE.md for project conventions. Pipeline added in Plan 02.
set -eu

# Force C locale for the whole pipeline. comm -23 requires its inputs to be
# sorted byte-identically; under a non-C locale (e.g. en_US.UTF-8 or
# tr_TR.UTF-8) sort uses locale-aware collation, which can silently desync
# the universe/keep ordering and produce wrong set arithmetic. Also
# stabilises awk regex matching.
LC_ALL=C
export LC_ALL

# --- Defaults (set before arg parsing) ---
profile=conservative
output=/etc/modprobe.d/modulejail-blacklist.conf

# --- Built-in baseline module lists (space-separated strings, not bash arrays) ---
# Each profile inherits from the one above via variable interpolation (DRY).
# Module names are in canonical underscore form; the pipeline normalizes both forms.

# BASELINE_MINIMAL (16 entries):
# Core filesystems, NLS deps for vfat/ESP, loop/overlay/autofs, crc32c/crc16.
# Intent: "Won't break a box that's already booted" — safety net for hosts
# where most drivers are compiled in but a few modular essentials remain.
BASELINE_MINIMAL='ext4 xfs btrfs vfat fat nls_cp437 nls_iso8859_1 nls_utf8 tmpfs loop overlay autofs4 crc32c_generic crc32c_intel libcrc32c crc16'

# BASELINE_CONSERVATIVE (MINIMAL + 39 entries ≈ 55 total):
# Virtio/KVM, common storage controllers, common ethernet NICs, HID/input,
# dm-crypt/LVM, and crypto primitives. Default profile (D-05).
# Intent: "Bare-metal or VM Linux server across the mainstream hardware matrix."
BASELINE_CONSERVATIVE="$BASELINE_MINIMAL virtio virtio_ring virtio_pci virtio_blk virtio_net virtio_scsi virtio_balloon virtio_rng nvme nvme_core ahci libahci libata sd_mod sr_mod scsi_mod usb_storage uas e1000 e1000e igb igc ixgbe r8169 tg3 bnxt_en bnx2 hid hid_generic usbhid i8042 dm_mod dm_crypt dm_mirror aes_generic aesni_intel sha256_generic xts cbc"

# BASELINE_DESKTOP (CONSERVATIVE + ~50 entries ≈ 105 total):
# Graphics/DRM, WiFi, Bluetooth, audio (ALSA/HDA), USB host controllers,
# misc desktop peripherals, and webcam/video4linux.
# Intent: "Laptop or workstation — won't break WiFi, BT, audio, or video."
# shellcheck disable=SC2034  # used by Plan 02 pipeline
BASELINE_DESKTOP="$BASELINE_CONSERVATIVE drm drm_kms_helper i915 amdgpu radeon nouveau nvidia ttm video backlight cfg80211 mac80211 iwlwifi iwlmvm iwldvm ath9k ath10k_core ath10k_pci ath11k brcmfmac brcmsmac rtw88_core rtw89_core rtl8xxxu bluetooth btusb btintel btrtl btbcm hci_uart snd snd_pcm snd_timer snd_hda_intel snd_hda_codec snd_hda_codec_realtek snd_hda_codec_hdmi snd_hda_codec_generic snd_usb_audio snd_seq xhci_hcd xhci_pci ehci_hcd ehci_pci uhci_hcd usblp cdc_acm joydev evdev videodev uvcvideo media"

# --- usage(): print help text; caller decides exit code ---
usage() {
    printf 'modulejail — shrink a Linux host'\''s kernel-module attack surface\n'
    printf '\n'
    printf 'Usage: modulejail [OPTIONS]\n'
    printf '\n'
    printf 'Options:\n'
    printf '  -p, --profile {minimal|conservative|desktop}\n'
    printf '                    Built-in baseline profile (default: conservative)\n'
    printf '  -o, --output PATH Output path for the generated blacklist file\n'
    printf '                    (default: /etc/modprobe.d/modulejail-blacklist.conf)\n'
    printf '  -h, --help        Show this help text and exit\n'
    printf '\n'
    printf 'Profiles:\n'
    printf '  minimal       Core filesystems + essential kernel modules only\n'
    printf '  conservative  Minimal + common server/VM drivers (default)\n'
    printf '  desktop       Conservative + WiFi, Bluetooth, audio, video drivers\n'
    printf '\n'
    printf 'Defaults:\n'
    printf '  profile: conservative\n'
    printf '  output:  /etc/modprobe.d/modulejail-blacklist.conf\n'
}

# --- Argument parser (manual case loop — POSIX, supports long options) ---
while [ $# -gt 0 ]; do
    case "$1" in
        -p|--profile)
            [ $# -ge 2 ] || { printf 'modulejail: %s requires an argument\n' "$1" >&2; exit 1; }
            profile=$2
            shift 2
            ;;
        --profile=*)
            profile=${1#--profile=}
            shift
            ;;
        -o|--output)
            [ $# -ge 2 ] || { printf 'modulejail: %s requires an argument\n' "$1" >&2; exit 1; }
            output=$2
            shift 2
            ;;
        --output=*)
            output=${1#--output=}
            shift
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        --)
            shift
            break
            ;;
        -*)
            printf 'modulejail: unknown option: %s\n' "$1" >&2
            exit 1
            ;;
        *)
            printf 'modulejail: unexpected positional argument: %s\n' "$1" >&2
            exit 1
            ;;
    esac
done

# --- Validate profile ---
case "$profile" in
    minimal|conservative|desktop) ;;
    *) printf 'modulejail: unknown profile: %s (expected minimal, conservative, desktop)\n' "$profile" >&2; exit 1 ;;
esac

# --- Pre-flight: verify this is a Linux host with the required kernel ---
# interfaces. Run this BEFORE the writability gate so non-Linux operators
# (e.g. macOS) get an accurate "not a Linux host" diagnostic instead of a
# misleading "cannot write to /etc/modprobe.d" message.
if [ ! -e /proc/modules ]; then
    printf 'modulejail: /proc/modules not found (is this a Linux host?)\n' >&2
    exit 1
fi
if [ ! -d "/lib/modules/$(uname -r)" ]; then
    printf 'modulejail: /lib/modules/%s does not exist (kernel module tree missing)\n' "$(uname -r)" >&2
    exit 1
fi

# --- Pre-flight: reject $output that is (or could become) a directory. ---
# Without this, `-o /etc/modprobe.d` (or any existing directory — easy slip
# with shell completion or a copy-paste from docs) would pass dirname, pass
# the writability gate, and have `mv` quietly drop the temp file *inside*
# the directory under its randomized name. modprobe ignores dotfiles, so
# the host would silently end up unprotected. Catch both forms here.
if [ -d "$output" ]; then
    printf 'modulejail: -o %s is a directory; expected a file path\n' "$output" >&2
    exit 1
fi
case "$output" in
    */) printf 'modulejail: -o %s ends with /, expected a file path\n' "$output" >&2; exit 1 ;;
esac

# --- Pre-flight: refuse a symlinked output target. ---
# `mv -- "$tmp" "$output"` would follow the symlink and replace the *target*,
# not the link. On a multi-tenant or misconfigured host this can write
# outside /etc/modprobe.d/. Honour the atomic-rename safety story (D-11/D-12)
# by refusing the symlink up front rather than silently following it.
if [ -L "$output" ]; then
    printf 'modulejail: refusing to overwrite symlink at %s\n' "$output" >&2
    exit 1
fi

# --- Pre-flight: writability gate (before any heavy work) ---
target_dir=$(dirname "$output")
if ! [ -w "$target_dir" ]; then
    printf 'modulejail: cannot write to %s (try sudo, or use -o <other-path>)\n' "$target_dir" >&2
    exit 1
fi

# === PIPELINE (Plan 02 onward) ===

# Per-invocation work directory — all intermediate sorted files live here.
# Cleaned up on any exit path (success, failure, signal).
workdir=$(mktemp -d -t modulejail.XXXXXX) || {
    printf 'modulejail: cannot create temporary work directory\n' >&2
    exit 1
}
trap 'rm -rf "$workdir"' EXIT INT HUP TERM

# list_universe: walk the FULL /lib/modules/$(uname -r) tree (NOT just kernel/)
# so DKMS and weak-updates modules are included (RESEARCH §1 / pitfall §12).
# Strip exactly the four known suffixes (.ko, .ko.gz, .ko.xz, .ko.zst);
# lines that do not match a known suffix are dropped (precision filter for
# the *.ko* glob). Normalize - to _ (RESEARCH §2). Output is sorted, deduped.
list_universe() {
    find "/lib/modules/$(uname -r)" -type f -name '*.ko*' 2>/dev/null \
    | awk '{
        n = $0
        # Keep only the basename
        sub(/.*\//, "", n)
        # Strip exactly one of the four known compression suffixes; drop others
        if (!sub(/\.ko\.gz$/, "", n) && \
            !sub(/\.ko\.xz$/, "", n) && \
            !sub(/\.ko\.zst$/, "", n) && \
            !sub(/\.ko$/, "", n)) next
        # Normalize - to _ (canonical underscore form, RESEARCH §2)
        gsub(/-/, "_", n)
        print n
    }' \
    | sort -u
}

# list_loaded: read currently-loaded modules from /proc/modules (RESEARCH §3).
# Uses /proc/modules directly — no kmod/lsmod runtime dep (Phase-2-PORT-02-friendly).
# Column 1 of /proc/modules is already in canonical underscore form.
list_loaded() {
    awk '{print $1}' /proc/modules | sort -u
}

# Produce the two canonical input files for set arithmetic.
list_universe > "$workdir/universe.txt"
list_loaded   > "$workdir/loaded.txt"

# list_baseline: expand the selected baseline profile ($profile) into a sorted,
# deduplicated list of canonical underscore module names.
# BASELINE_* variables are POSIX space-separated strings (NOT bash arrays — RESEARCH §8
# anti-pattern). We expand them via intentional word-splitting.
list_baseline() {
    case "$profile" in
        minimal)      list=$BASELINE_MINIMAL ;;
        conservative) list=$BASELINE_CONSERVATIVE ;;
        desktop)      list=$BASELINE_DESKTOP ;;
    esac
    # intentional word-splitting — BASELINE_* are POSIX space-separated lists, not bash arrays
    # shellcheck disable=SC2086
    for x in $list; do
        printf '%s\n' "$x"
    done \
    | tr '-' '_' \
    | sort -u
}

list_baseline > "$workdir/baseline.txt"

# Compose total keep-list: loaded modules union baseline (sorted, deduped).
cat "$workdir/loaded.txt" "$workdir/baseline.txt" | sort -u > "$workdir/keep.txt"

# Set difference: blacklist = universe − keep (RESEARCH Pattern 1).
# comm -23 requires both inputs to be sorted; both universe.txt and keep.txt are.
comm -23 "$workdir/universe.txt" "$workdir/keep.txt" > "$workdir/blacklist.txt"

# Expose result path for Plan 03's renderer.
# shellcheck disable=SC2034  # used by Plan 03 renderer
blacklist="$workdir/blacklist.txt"

# Sanity guard (RESEARCH §11): abort on degenerate output to avoid
# bricking a host with an empty or near-total blacklist.
universe_count=$(wc -l < "$workdir/universe.txt")
blacklist_count=$(wc -l < "$workdir/blacklist.txt")

if [ "$blacklist_count" -eq 0 ]; then
    printf 'modulejail: computed blacklist is empty; nothing to write.\n' >&2
    printf 'modulejail: check that /proc/modules is readable and the baseline list is correct.\n' >&2
    exit 1
fi

if [ "$((blacklist_count * 100))" -gt "$((universe_count * 99))" ]; then
    printf 'modulejail: computed blacklist covers %d of %d modules (>99%% of universe).\n' \
        "$blacklist_count" "$universe_count" >&2
    printf 'modulejail: This usually means /proc/modules was unreadable or the baseline list is wrong.\n' >&2
    printf 'modulejail: Aborting to avoid an unbootable host.\n' >&2
    exit 1
fi

# === RENDER (Plan 03) ===
# Render $blacklist into install /bin/true directives and write atomically to $output.
# Atomic write: mktemp in same dir as $output → chmod 0644 → mv (single rename(2)).
# This guarantees readers see either the pre-run file or the post-run file, never a
# partial write (RESEARCH §7 Pattern 2; D-11).

# target_dir already computed above (writability gate); reuse it.
tmp=$(mktemp "${target_dir}/.modulejail-blacklist.conf.XXXXXX") || {
    printf 'modulejail: cannot create temp file in %s\n' "$target_dir" >&2
    exit 1
}

# Extend the cleanup trap to also remove $tmp on any exit path (signal, failure,
# or — harmlessly, since the file will be gone — success after mv).
# We redefine cleanup() to cover both $workdir and $tmp, then re-register the trap.
# shellcheck disable=SC2329  # invoked via trap string, not direct call
cleanup() {
    rm -rf "$workdir"
    rm -f  "$tmp"
}
trap cleanup EXIT INT HUP TERM

# Write 4-line header + one `install <mod> /bin/true` line per blacklisted module.
# Header has NO version string and NO timestamp — those are Phase 2 / CORE-05.
{
    printf '# modulejail blacklist (Phase 1 minimum viable)\n'
    printf '# Generated from /proc/modules + built-in baseline.\n'
    printf '# Each line below intercepts modprobe and runs /bin/true.\n'
    printf '# Do not edit by hand — see https://github.com/jnuyens/modulejail\n'
    awk '{print "install " $1 " /bin/true"}' "$blacklist"
} > "$tmp"

# Set world-readable permissions before rename (umask may be too restrictive;
# modprobe.d files must be readable by all — RESEARCH §7 rule 3).
chmod 0644 "$tmp"

# Atomic rename: single rename(2) syscall; same filesystem guaranteed because
# $tmp is in $(dirname "$output") (RESEARCH §7 rule 1; D-11, D-12).
mv -- "$tmp" "$output"

exit 0
